<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude database and preferences from backup and transfer -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="cs360_weight_tracker.db" />
        <exclude domain="database" path="cs360_weight_tracker.db-wal" />
        <exclude domain="database" path="cs360_weight_tracker.db-shm" />
        <exclude domain="sharedpref" path="cs360_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="cs360_weight_tracker.db" />
        <exclude domain="database" path="cs360_weight_tracker.db-wal" />
        <exclude domain="database" path="cs360_weight_tracker.db-shm" />
        <exclude domain="sharedpref" path="cs360_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
